FROM debian:trixie-slim

# Update package lists and install dependencies
RUN apt-get update && apt-get install -y \
    libcpprest-dev \
    curl \
    wget \
    bash \
    gdb \
    cmake \
    libssl-dev \
    zlib1g-dev \
    build-essential \
    libboost-all-dev \
    git \
    nlohmann-json3-dev \
    libopenblas-dev \
    pkg-config \
    ca-certificates \
    python3 \
    python3-pip \
    && rm -rf /var/lib/apt/lists/*

# Install ONNX Runtime (for Silero VAD support)
RUN apt-get update && apt-get install -y \
    libonnxruntime-dev \
    || echo "ONNX Runtime dev package not available, using pip version"


WORKDIR /app

# Initialize git and clean up
RUN git init

# Add git submodules
RUN git submodule add https://github.com/deepkhurana1999/whisper.cpp.git ./libraries/whisper.cpp
RUN git submodule add https://github.com/paullouisageneau/libdatachannel.git ./libraries/libdatachannel
RUN git submodule update --init --recursive

# Checkout specific versions
RUN cd libraries/libdatachannel && git checkout v0.23.2
RUN cd libraries/whisper.cpp && git checkout v1.8.0_parallel

# Create models directory and download whisper model
RUN mkdir /models
RUN /app/libraries/whisper.cpp/models/download-ggml-model.sh base /models

# Download Silero VAD model for Voice Activity Detection
RUN mkdir -p /models/vad && \
    wget -O /models/vad/silero_vad.onnx \
    https://github.com/snakers4/silero-vad/raw/master/src/silero_vad/data/silero_vad.onnx

# Copy application files
COPY ./backend/include /app/include
COPY ./backend/src /app/src
COPY ./backend/CMakeLists.txt /app/CMakeLists.txt
COPY ./backend/entrypoint.sh /app/entrypoint.sh

ENTRYPOINT [ "bash", "/app/entrypoint.sh" ]
